@page
@model IndexModel
@{
    ViewData["Title"] = "Marketplace";
}

<h1>Marketplace</h1>

@if (!Model.IsLoggedIn)
{
    <h2>Login</h2>

    <form method="post" asp-page-handler="Login">
        <label for="email">Email:</label><br />
        <input id="email" name="Email" type="email" required /><br /><br />

        <label for="password">Password:</label><br />
        <input id="password" name="Password" type="password" required /><br /><br />

        <button type="submit">Log In</button>
    </form>

    <h2>Create Account</h2>

    <form method="post" asp-page-handler="CreateAccount">
        <label for="createEmail">Email:</label><br />
        <input id="createEmail" name="Email" type="email" required /><br /><br />

        <label for="createPassword">Password:</label><br />
        <input id="createPassword" name="Password" type="password" required /><br /><br />

        <button type="submit">Create Account</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p>@Model.Message</p>
    }
}
else
{
    <p>Welcome, @Model.UserEmail!</p>

    <form method="post" asp-page-handler="Logout">
        <button type="submit">Log Out</button>
    </form>

    <h2>Create Product</h2>

    <form method="post" asp-page-handler="CreateProduct">
        <label for="productName">Product Name:</label><br />
        <input id="productName" name="ProductName" type="text" required /><br /><br />

        <label for="price">Price:</label><br />
        <input id="price" name="Price" type="number" step="0.01" required /><br /><br />

        <label for="inventory">Inventory:</label><br />
        <input id="inventory" name="Inventory" type="number" min="0" required /><br /><br />

        <button type="submit">Create Product</button>
    </form>

    <h2>Products</h2>

    @if (Model.Products.Any())
    {
        <ul>
        @foreach (var product in Model.Products)
        {
            <li>
                @product.ProductName - $@product.Price - Inventory: @product.Inventory - Seller: @product.SellerEmail

                @if (Model.IsLoggedIn && Model.UserEmail == product.SellerEmail)
                {
                    <form method="post" asp-page-handler="StartEdit" style="display:inline;">
                        <input type="hidden" name="id" value="@product.Id" />
                        <button type="submit">Edit</button>
                    </form>

                    <form method="post" asp-page-handler="DeleteProduct" style="display:inline;">
                        <input type="hidden" name="id" value="@product.Id" />
                        <button type="submit">Delete</button>
                    </form>
                }
            </li>
        }
        </ul>
    }
    else
    {
        <p>No products available.</p>
    }

    @if (Model.IsEditing)
    {
        <h2>Edit Product</h2>

        <form method="post" asp-page-handler="UpdateProduct">
            <input type="hidden" asp-for="EditProductId" />

            <label asp-for="EditProductName">Product Name:</label><br />
            <input asp-for="EditProductName" /><br /><br />

            <label asp-for="EditPrice">Price:</label><br />
            <input asp-for="EditPrice" type="number" step="0.01" /><br /><br />

            <label asp-for="EditInventory">Inventory:</label><br />
            <input asp-for="EditInventory" type="number" min="0" /><br /><br />

            <button type="submit">Update Product</button>
        </form>
    }

    <h2>Purchase Product</h2>

    <form method="post" asp-page-handler="Purchase">
        <label for="productId">Product:</label><br />
        <select id="productId" name="SelectedProductId" required>
            @foreach (var product in Model.Products)
            {
                <option value="@product.Id">
                    @product.ProductName (Inventory: @product.Inventory)
                </option>
            }
        </select><br /><br />

        <label for="quantity">Quantity:</label><br />
        <input id="quantity" name="Quantity" type="number" min="1" required /><br /><br />

        <button type="submit">Purchase</button>
    </form>

    @if (Model.IsLoggedIn)
   {
    <h2>My Orders</h2>

    @if (Model.BuyerOrders.Any())
    {
        <ul>
        @foreach (var order in Model.BuyerOrders)
        {
            <li>
                Product: @order.Product.ProductName |
                Seller: @order.Product.SellerEmail |
                Quantity: @order.Quantity
            </li>
        }
        </ul>
    }
    else
    {
        <p>You have not placed any orders yet.</p>
    }
    }

    @if (Model.IsLoggedIn)
    {
    <h2>Orders for My Products</h2>

    @if (Model.SellerOrders.Any())
    {
        <ul>
        @foreach (var order in Model.SellerOrders)
        {
            <li>
                Product: @order.Product.ProductName |
                Buyer: @order.BuyerEmail |
                Quantity: @order.Quantity
            </li>
        }
        </ul>
    }
    else
    {
        <p>No orders for your products yet.</p>
    }
    }

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p>@Model.Message</p>
    }
}